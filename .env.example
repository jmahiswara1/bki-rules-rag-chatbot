OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=your-ollama-model-name

EMBEDDING_MODEL=your-embedding-model-name

CHROMA_COLLECTION=your-chroma-collection-name

CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=8
MAX_RETRIEVAL_DISTANCE=1.10
FALLBACK_MAX_RETRIEVAL_DISTANCE=1.30
RETRIEVAL_DISTANCE_MARGIN=0.20
MIN_CONTEXT_MATCHES=1
FINAL_CONTEXT_K=4
MIN_KEYWORD_OVERLAP=0.00
KEYWORD_GATE_MIN_RATIO=0.20
CONSERVATIVE_MODE=1
MIN_QUOTE_TOKEN_OVERLAP=0.30

# Optional: set if you want higher HF Hub rate limits
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# Optional: aktifkan reranker untuk akurasi retrieval lebih baik (latensi naik)
# USE_CROSS_ENCODER_RERANKER=1
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
